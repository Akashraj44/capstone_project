pipeline {
	
agent any

tools {
    maven 'Maven3'
    jdk 'JDK'
}

stages {

    stage('Checkout') {
        steps {
            git branch: 'main',
                url: 'https://github.com/Akashraj44/capstone_project.git'
        }
    }

    stage('Clean') {
        steps {
            bat 'mvn clean'
        }
    }

    stage('Compile') {
        steps {
            bat 'mvn compile'
        }
    }

    stage('Test') {
        steps {
            bat 'mvn test'
        }
    }

    stage('Package') {
        steps {
            bat 'mvn package'
        }
    }

    stage('Docker Build') {
        steps {
            bat 'docker build -t guru99-framework .'
        }
    }

    stage('Docker Run') {
        steps {
            bat 'docker run --rm guru99-framework'
        }
    }
}

post {

    success {
        echo 'Guru99 Framework Build Successful'
    }

    failure {
        echo 'Guru99 Framework Build Failed'
    }

    always {
        echo 'Pipeline Execution Completed'
    }
}

}
